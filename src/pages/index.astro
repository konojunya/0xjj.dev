---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main>
		<header class="site-header">
			<span class="handle">0xJJ.dev<span class="cursor">_</span></span>
		</header>

		<section class="hero">
			<h1>
				<span class="word" style="--delay: 0ms">Coming</span>
				<span class="word" style="--delay: 140ms">Soon</span>
			</h1>
			<p class="tagline">Something new is on its way.</p>
		</section>

		<footer class="site-footer">
			<span class="year">© 2026</span>
		</footer>
	</main>
</Layout>

<style>
	main {
		min-height: 100svh;
		display: grid;
		grid-template-rows: auto 1fr auto;
		padding: clamp(1.5rem, 5vw, 3rem);
		background-color: var(--color-bg);
		color: var(--color-fg);
		box-sizing: border-box;
	}

	/* ── Header ── */
	.site-header {
		display: flex;
		align-items: center;
	}

	.handle {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		letter-spacing: 0.06em;
		color: var(--color-muted);
	}

	.cursor {
		color: var(--color-accent);
		animation: blink 1.1s step-end infinite;
		margin-left: 1px;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50%       { opacity: 0; }
	}

	/* ── Hero ── */
	.hero {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	h1 {
		font-family: var(--font-display);
		font-style: italic;
		font-weight: 400;
		font-size: clamp(4.5rem, 16vw, 13rem);
		line-height: 0.88;
		letter-spacing: -0.02em;
		margin: 0 0 clamp(1.5rem, 4vw, 2.5rem);
	}

	.word {
		display: block;
		padding-bottom: 0.18em;
		clip-path: inset(0 0 100% 0);
		animation: reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		animation-delay: var(--delay, 0ms);
	}

	@keyframes reveal {
		to { clip-path: inset(0 0 0% 0); }
	}

	.tagline {
		font-family: var(--font-mono);
		font-size: clamp(0.7rem, 1.8vw, 0.85rem);
		color: var(--color-muted);
		letter-spacing: 0.04em;
		margin: 0;
		opacity: 0;
		animation: fadein 0.5s ease forwards;
		animation-delay: 480ms;
	}

	@keyframes fadein {
		to { opacity: 1; }
	}

	/* ── Footer ── */
	.site-footer {
		display: flex;
		justify-content: flex-end;
		align-items: flex-end;
	}

	.year {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.06em;
		color: var(--color-muted);
	}
</style>
