{
  "name": "0xjj",
  "compatibility_date": "2026-02-24",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "analytics_engine_datasets": [
    { "binding": "AE_BLOG", "dataset": "blog_views" }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
