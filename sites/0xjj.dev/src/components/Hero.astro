---
---

<section class="hero">
  <img src="/animate-icon.svg" alt="" class="icon" aria-hidden="true" />
  <h1 class="name">Hello, I'm JJ.</h1>
  <nav class="socials" aria-label="Social links">
    <a href="https://x.com/0xjj_official" target="_blank" rel="noopener noreferrer">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      <span>0xjj_official</span>
    </a>
    <a href="https://github.com/konojunya" target="_blank" rel="noopener noreferrer">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      <span>konojunya</span>
    </a>
  </nav>
  <div class="scroll-hint" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M8 3v10M3 9l5 5 5-5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    padding: 2rem;
    text-align: center;
    position: relative;
  }

  .icon {
    height: 160px;
    width: auto;
    display: block;
  }

  .name {
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 5rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0;
    background: linear-gradient(
      90deg,
      var(--color-fg) 0%,
      var(--color-fg) 35%,
      #bc7aff 50%,
      var(--color-fg) 65%,
      var(--color-fg) 100%
    );
    background-size: 250% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 5s linear infinite;
  }

  @keyframes shimmer {
    0%   { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  .socials {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }

  .socials a {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-muted);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .socials a:hover {
    color: var(--color-fg);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-muted);
    animation: nudge 2.4s ease-in-out infinite;
  }

  @keyframes nudge {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.5; }
    50%       { transform: translateX(-50%) translateY(6px); opacity: 1; }
  }
</style>
