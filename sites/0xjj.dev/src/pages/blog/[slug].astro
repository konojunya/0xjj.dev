---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { readingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(p => !p.data.externalUrl);
  const sorted = posts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const minutes = readingTime(post.body ?? '');

function excerpt(body: string, maxLen = 150): string {
  return body
    .replace(/```[\s\S]*?```/g, '')   // fenced code blocks
    .replace(/`[^`]*`/g, '')          // inline code
    .replace(/!\[.*?\]\(.*?\)/g, '')  // images
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // links → text
    .replace(/^#{1,6}\s+/gm, '')      // headings
    .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, '$1') // bold/italic
    .replace(/^\s*[-*>]\s+/gm, '')    // list markers / blockquotes
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, maxLen)
    .replace(/\s\S*$/, '…');          // trim at word boundary
}

const description = excerpt(post.body ?? '');
---

<Layout title={post.data.title} description={description} ogImage={`https://0xjj.dev/og/${post.id}.png`} jsonLd={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "image": `https://0xjj.dev/og/${post.id}.png`,
  "datePublished": post.data.date.toISOString(),
  "author": { "@type": "Person", "name": "Junya Kono", "url": "https://0xjj.dev" },
  "publisher": { "@type": "Person", "name": "Junya Kono", "url": "https://0xjj.dev" },
  "description": description,
  "mainEntityOfPage": `https://0xjj.dev/blog/${post.id}`
})}>
  <div class="container">
    <a href="/blog" class="back">← Blog</a>
    <article>
      <header style={`--hero-bg: url('/og/bg/${post.id}.png')`} transition:name={`blog-thumb-${post.id}`}>
        <h1 transition:name={`blog-title-${post.id}`}>{post.data.title}</h1>
        <div class="meta">
          <time class="date">{dateStr}</time>
          <span class="sep date-sep">·</span>
          <span class="meta-stats">
            <span class="reading-time">{minutes} min read</span>
            <span class="sep view-sep" style="display:none">·</span>
            <span class="view-count" style="display:none"></span>
          </span>
        </div>
      </header>
      {post.data.isAIGen && (
        <div class="ai-badge-wrap">
          <span class="ai-badge">
            Written by AI
            <button class="ai-badge-help" type="button" aria-label="Why AI?">?</button>
          </span>
          <div class="ai-badge-tooltip" role="tooltip">
            この記事は AI によって作成されました。記事を大量生産する目的ではなく、備忘録として情報を整理・記録するために AI を活用しています。
          </div>
        </div>
      )}
      {tocHeadings.length >= 2 && (
        <nav class="toc" aria-label="Table of contents">
          <span class="toc-label">contents</span>
          <ol class="toc-list">
            {tocHeadings.map(h => (
              <li class={`toc-item toc-item--h${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}
      <div class="prose">
        <Content />
      </div>
    </article>

    <nav class="post-nav">
      <div class="post-nav-item post-nav-prev">
        {prev && (
          <a href={`/blog/${prev.id}`}>
            <span class="post-nav-label">← Older</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        )}
      </div>
      <div class="post-nav-item post-nav-next">
        {next && (
          <a href={`/blog/${next.id}`}>
            <span class="post-nav-label">Newer →</span>
            <span class="post-nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>

    <div class="edit-on-github">
      <a href={`https://github.com/konojunya/0xjj.dev/edit/main/sites/0xjj.dev/src/content/blog/${post.id}.md`} target="_blank" rel="noreferrer noopener">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
        Edit on GitHub
      </a>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const helpBtn = document.querySelector('.ai-badge-help');
    const tooltip = document.querySelector('.ai-badge-tooltip');
    if (helpBtn && tooltip) {
      helpBtn.addEventListener('click', () => {
        tooltip.classList.toggle('is-open');
      });
    }

    const slug = location.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
    if (!slug) return;
    // Track view (fire-and-forget)
    fetch(`/api/views/${slug}`, { method: 'POST' }).catch(() => {});
    // Fetch and display view count
    fetch(`/api/views/${slug}`)
      .then(r => r.json())
      .then((data: { views: number }) => {
        const sep = document.querySelector('.view-sep');
        const el = document.querySelector('.view-count');
        if (el && data.views > 0) {
          el.textContent = `${data.views.toLocaleString()} views`;
          (el as HTMLElement).style.display = '';
          if (sep) (sep as HTMLElement).style.display = '';
        }
      })
      .catch(() => {});
  });
</script>

<style>
  .container {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 5rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .back:hover {
    color: var(--color-fg);
  }

  article header {
    position: relative;
    margin: 0 0 2.5rem;
    padding: 1.75rem 1.75rem 1.5rem;
    border-radius: 20px;
    overflow: hidden;
    /* pastel shader bg + milky translucent glaze */
    background:
      linear-gradient(135deg, rgba(255,255,255,0.52) 0%, rgba(255,255,255,0.18) 55%, rgba(210,190,255,0.1) 100%),
      var(--hero-bg, transparent) center top / cover no-repeat;
    /* bubble rim */
    border: 1px solid rgba(255,255,255,0.5);
    box-shadow:
      0 2px 24px rgba(110,80,200,0.10),
      inset 0 1.5px 0 rgba(255,255,255,0.7),
      inset 0 -1px 0 rgba(190,170,230,0.18);
  }

  /* specular highlight — the bright glint of a soap bubble */
  article header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 60%;
    height: 55%;
    background: radial-gradient(
      ellipse 65% 55% at 28% 22%,
      rgba(255,255,255,0.58) 0%,
      rgba(255,255,255,0.12) 45%,
      transparent 70%
    );
    pointer-events: none;
  }

  h1 {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    font-style: normal;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    /* always dark — bubble background is always a light pastel */
    color: #1e0e4e;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(30, 14, 78, 0.55);
    letter-spacing: 0.04em;
  }

  .meta-stats {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  @media (max-width: 639px) {
    .meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }
    .date-sep {
      display: none;
    }
  }

  .sep { opacity: 0.5; }

  .date, .reading-time { color: rgba(30, 14, 78, 0.55); }

  .toc {
    margin: 0 0 2.5rem;
    padding: 1rem 1.25rem;
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-fg) 2.5%, transparent);
  }

  .toc-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.625rem;
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .toc-item a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-muted);
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--color-fg);
  }

  .toc-item--h3 {
    padding-left: 1rem;
  }

  .toc-item--h3 a::before {
    content: '↳ ';
    opacity: 0.4;
  }

  .prose {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-fg);
  }

  .prose :global(p) {
    margin: 0 0 1.25em;
  }

  .prose :global(h2) {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    font-style: normal;
    margin: 2.5rem 0 0.75rem;
    color: var(--color-fg);
  }

  .prose :global(h3) {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    font-style: normal;
    margin: 2rem 0 0.5rem;
    color: var(--color-fg);
  }

  .prose :global(h4) {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    color: var(--color-fg);
  }

  .prose :global(a) {
    color: var(--color-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-fg) 30%, transparent);
    transition: text-decoration-color 0.15s ease;
    overflow-wrap: break-word;
    word-break: break-all;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-fg);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: color-mix(in srgb, var(--color-fg) 7%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    word-break: break-all;
    overflow-wrap: break-word;
  }

  .prose :global(pre) {
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    max-width: 100%;
    margin: 1.5rem 0;
    position: relative;
  }

  .prose :global(pre[data-has-filename]) {
    padding-top: 2.5rem;
  }

  .prose :global(.code-filename) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 0.35rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    border-bottom: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    letter-spacing: 0.03em;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    border-left: 2px solid color-mix(in srgb, var(--color-fg) 18%, transparent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25em;
    padding-left: 0;
    list-style: none;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
    padding-left: 1.25em;
    position: relative;
  }

  .prose :global(ul > li::before) {
    content: '-';
    position: absolute;
    left: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  .prose :global(ol) {
    counter-reset: ol-counter;
  }

  .prose :global(ol > li) {
    counter-increment: ol-counter;
  }

  .prose :global(ol > li::before) {
    content: counter(ol-counter) '.';
    position: absolute;
    left: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.82em;
  }

  .prose :global(.zenn-message) {
    margin: 1.5rem 0;
    padding: 0.875rem 1.25rem;
    border-radius: 6px;
    border-left: 3px solid;
    font-size: 0.9em;
    line-height: 1.7;
  }

  .prose :global(.zenn-message--info) {
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border-color: color-mix(in srgb, var(--color-fg) 25%, transparent);
  }

  .prose :global(.zenn-message--alert) {
    background: color-mix(in srgb, #f59e0b 8%, transparent);
    border-color: #f59e0b;
  }

  .prose :global(.zenn-message p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose :global(th) {
    text-align: left;
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid color-mix(in srgb, var(--color-fg) 20%, transparent);
    color: var(--color-fg);
  }

  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    vertical-align: top;
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
  }

  .post-nav-item a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
  }

  .post-nav-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .post-nav-title {
    font-size: 0.875rem;
    color: var(--color-fg);
    line-height: 1.4;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-fg) 30%, transparent);
    transition: text-decoration-color 0.15s ease;
  }

  .post-nav-item a:hover .post-nav-title {
    text-decoration-color: var(--color-fg);
  }

  .post-nav-next {
    text-align: right;
  }

  .edit-on-github {
    margin-top: 2rem;
    text-align: center;
  }

  .edit-on-github a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s ease;
  }

  .edit-on-github a:hover {
    color: var(--color-fg);
  }

  .ai-badge-wrap {
    margin-bottom: 1.5rem;
  }

  .ai-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 6px;
    padding: 0.3rem 0.6rem;
  }

  .ai-badge-help {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1rem;
    height: 1rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-fg) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 15%, transparent);
    border-radius: 50%;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
    padding: 0;
  }

  .ai-badge-help:hover {
    color: var(--color-fg);
    border-color: color-mix(in srgb, var(--color-fg) 30%, transparent);
  }

  .ai-badge-tooltip {
    display: none;
    margin-top: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--color-muted);
    background: color-mix(in srgb, var(--color-fg) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 8px;
  }

  .ai-badge-tooltip.is-open {
    display: block;
  }
</style>
