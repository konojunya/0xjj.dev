---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { readingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = posts.sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i - 1] ?? null,
      next: sorted[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const minutes = readingTime(post.body ?? '');

function excerpt(body: string, maxLen = 150): string {
  return body
    .replace(/```[\s\S]*?```/g, '')   // fenced code blocks
    .replace(/`[^`]*`/g, '')          // inline code
    .replace(/!\[.*?\]\(.*?\)/g, '')  // images
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // links → text
    .replace(/^#{1,6}\s+/gm, '')      // headings
    .replace(/[*_]{1,2}([^*_]+)[*_]{1,2}/g, '$1') // bold/italic
    .replace(/^\s*[-*>]\s+/gm, '')    // list markers / blockquotes
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, maxLen)
    .replace(/\s\S*$/, '…');          // trim at word boundary
}

const description = excerpt(post.body ?? '');
---

<Layout title={post.data.title}>
  <meta slot="head" name="description" content={description} />
  <meta slot="head" property="og:title" content={post.data.title} />
  <meta slot="head" property="og:description" content={description} />
  <meta slot="head" property="og:type" content="article" />
  <meta slot="head" property="og:image" content={`/og/${post.id}.png`} />
  <meta slot="head" property="og:url" content={`https://0xjj.dev/blog/${post.id}`} />
  <meta slot="head" name="twitter:card" content="summary_large_image" />
  <meta slot="head" name="twitter:image" content={`/og/${post.id}.png`} />
  <div class="container">
    <a href="/blog" class="back">← Blog</a>
    <article>
      <header style={`--hero-bg: url('/og/bg/${post.id}.png')`} transition:name={`blog-thumb-${post.id}`}>
        <h1 transition:name={`blog-title-${post.id}`}>{post.data.title}</h1>
        <div class="meta">
          <time class="date">{dateStr}</time>
          <span class="sep">·</span>
          <span class="reading-time">{minutes} min read</span>
        </div>
      </header>
      {tocHeadings.length >= 2 && (
        <nav class="toc" aria-label="Table of contents">
          <span class="toc-label">contents</span>
          <ol class="toc-list">
            {tocHeadings.map(h => (
              <li class={`toc-item toc-item--h${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}
      <div class="prose">
        <Content />
      </div>
    </article>

    <nav class="post-nav">
      <div class="post-nav-item post-nav-prev">
        {prev && (
          <a href={`/blog/${prev.id}`}>
            <span class="post-nav-label">← Older</span>
            <span class="post-nav-title">{prev.data.title}</span>
          </a>
        )}
      </div>
      <div class="post-nav-item post-nav-next">
        {next && (
          <a href={`/blog/${next.id}`}>
            <span class="post-nav-label">Newer →</span>
            <span class="post-nav-title">{next.data.title}</span>
          </a>
        )}
      </div>
    </nav>
  </div>
</Layout>

<style>
  .container {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .back:hover {
    color: var(--color-fg);
  }

  article header {
    position: relative;
    margin: 0 0 2.5rem;
    padding: 1.75rem 1.75rem 1.5rem;
    border-radius: 20px;
    overflow: hidden;
    /* pastel shader bg + milky translucent glaze */
    background:
      linear-gradient(135deg, rgba(255,255,255,0.52) 0%, rgba(255,255,255,0.18) 55%, rgba(210,190,255,0.1) 100%),
      var(--hero-bg, transparent) center top / cover no-repeat;
    /* bubble rim */
    border: 1px solid rgba(255,255,255,0.5);
    box-shadow:
      0 2px 24px rgba(110,80,200,0.10),
      inset 0 1.5px 0 rgba(255,255,255,0.7),
      inset 0 -1px 0 rgba(190,170,230,0.18);
  }

  /* specular highlight — the bright glint of a soap bubble */
  article header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 60%;
    height: 55%;
    background: radial-gradient(
      ellipse 65% 55% at 28% 22%,
      rgba(255,255,255,0.58) 0%,
      rgba(255,255,255,0.12) 45%,
      transparent 70%
    );
    pointer-events: none;
  }

  h1 {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    font-style: normal;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    /* always dark — bubble background is always a light pastel */
    color: #1e0e4e;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(30, 14, 78, 0.55);
    letter-spacing: 0.04em;
  }

  .sep { opacity: 0.5; }

  .date, .reading-time { color: rgba(30, 14, 78, 0.55); }

  .toc {
    margin: 0 0 2.5rem;
    padding: 1rem 1.25rem;
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-fg) 2.5%, transparent);
  }

  .toc-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 0.625rem;
  }

  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .toc-item a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-muted);
    text-decoration: none;
    line-height: 1.5;
    transition: color 0.15s ease;
  }

  .toc-item a:hover {
    color: var(--color-fg);
  }

  .toc-item--h3 {
    padding-left: 1rem;
  }

  .toc-item--h3 a::before {
    content: '↳ ';
    opacity: 0.4;
  }

  .prose {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-fg);
  }

  .prose :global(p) {
    margin: 0 0 1.25em;
  }

  .prose :global(h2) {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.35rem;
    font-weight: 700;
    font-style: normal;
    margin: 2.5rem 0 0.75rem;
    color: var(--color-fg);
  }

  .prose :global(h3) {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    font-style: normal;
    margin: 2rem 0 0.5rem;
    color: var(--color-fg);
  }

  .prose :global(h4) {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
    color: var(--color-fg);
  }

  .prose :global(a) {
    color: var(--color-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-fg) 30%, transparent);
    transition: text-decoration-color 0.15s ease;
    overflow-wrap: break-word;
    word-break: break-all;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-fg);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: color-mix(in srgb, var(--color-fg) 7%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    word-break: break-all;
    overflow-wrap: break-word;
  }

  .prose :global(pre) {
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    max-width: 100%;
    margin: 1.5rem 0;
    position: relative;
  }

  .prose :global(pre[data-has-filename]) {
    padding-top: 2.5rem;
  }

  .prose :global(.code-filename) {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    padding: 0.35rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    border-bottom: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    letter-spacing: 0.03em;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    border-left: 2px solid color-mix(in srgb, var(--color-fg) 18%, transparent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25em;
    padding-left: 0;
    list-style: none;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
    padding-left: 1.25em;
    position: relative;
  }

  .prose :global(ul > li::before) {
    content: '-';
    position: absolute;
    left: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
  }

  .prose :global(ol) {
    counter-reset: ol-counter;
  }

  .prose :global(ol > li) {
    counter-increment: ol-counter;
  }

  .prose :global(ol > li::before) {
    content: counter(ol-counter) '.';
    position: absolute;
    left: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.82em;
  }

  .prose :global(.zenn-message) {
    margin: 1.5rem 0;
    padding: 0.875rem 1.25rem;
    border-radius: 6px;
    border-left: 3px solid;
    font-size: 0.9em;
    line-height: 1.7;
  }

  .prose :global(.zenn-message--info) {
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border-color: color-mix(in srgb, var(--color-fg) 25%, transparent);
  }

  .prose :global(.zenn-message--alert) {
    background: color-mix(in srgb, #f59e0b 8%, transparent);
    border-color: #f59e0b;
  }

  .prose :global(.zenn-message p:last-child) {
    margin-bottom: 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
  }

  .prose :global(th) {
    text-align: left;
    font-weight: 600;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid color-mix(in srgb, var(--color-fg) 20%, transparent);
    color: var(--color-fg);
  }

  .prose :global(td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    vertical-align: top;
  }

  .prose :global(tr:last-child td) {
    border-bottom: none;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
  }

  .post-nav-item a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    text-decoration: none;
  }

  .post-nav-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .post-nav-title {
    font-size: 0.875rem;
    color: var(--color-fg);
    line-height: 1.4;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-fg) 30%, transparent);
    transition: text-decoration-color 0.15s ease;
  }

  .post-nav-item a:hover .post-nav-title {
    text-decoration-color: var(--color-fg);
  }

  .post-nav-next {
    text-align: right;
  }
</style>
