---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const dateStr = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={post.data.title}>
  <div class="container">
    <a href="/" class="back">← Back</a>
    <article>
      <header>
        <h1>{post.data.title}</h1>
        <time class="date">{dateStr}</time>
      </header>
      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</Layout>

<style>
  .container {
    max-width: 42rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .back:hover {
    color: var(--color-fg);
  }

  article header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 0.75rem;
    color: var(--color-fg);
  }

  .date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .prose {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-fg);
  }

  .prose :global(p) {
    margin: 0 0 1.25em;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    margin: 2.5rem 0 0.75rem;
    color: var(--color-fg);
  }

  .prose :global(h3) {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    margin: 2rem 0 0.5rem;
  }

  .prose :global(a) {
    color: var(--color-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-fg) 30%, transparent);
    transition: text-decoration-color 0.15s ease;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-fg);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: color-mix(in srgb, var(--color-fg) 7%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .prose :global(pre) {
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.82rem;
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    border-left: 2px solid color-mix(in srgb, var(--color-fg) 18%, transparent);
    margin: 1.5rem 0;
    padding: 0.25rem 0 0.25rem 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25em;
    padding-left: 1.5em;
  }

  .prose :global(li) {
    margin-bottom: 0.4em;
  }
</style>
