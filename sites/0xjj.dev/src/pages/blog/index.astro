---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { readingTime } from '../../lib/reading-time';

const posts = await getCollection('blog');
const sorted = posts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map(post => ({
    id: post.id,
    title: post.data.title,
    date: post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
    minutes: readingTime(post.body ?? ''),
    externalUrl: post.data.externalUrl,
  }));
---

<Layout title="Blog" description="JJ's blog posts on web development, blockchain, and more." jsonLd={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Blog",
  "url": "https://0xjj.dev/blog/",
  "description": "JJ's blog posts on web development, blockchain, and more."
})}>
  <div class="container">
    <a href="/" class="back">← Back</a>

    <header>
      <h1>Blog</h1>
      <a href="/rss.xml" class="rss" aria-label="RSS feed">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </header>

    <section id="popular-posts">
      <h2 class="popular-heading">Popular</h2>
      <ul class="popular-list" id="popular-list">
        <li class="popular-item popular-skeleton"><div class="popular-link skeleton-link"><span class="skeleton-bar skeleton-bar--medal"></span><span class="popular-info"><span class="skeleton-bar skeleton-bar--title"></span><span class="skeleton-bar skeleton-bar--views"></span></span></div></li>
        <li class="popular-item popular-skeleton"><div class="popular-link skeleton-link"><span class="skeleton-bar skeleton-bar--medal"></span><span class="popular-info"><span class="skeleton-bar skeleton-bar--title"></span><span class="skeleton-bar skeleton-bar--views"></span></span></div></li>
        <li class="popular-item popular-skeleton"><div class="popular-link skeleton-link"><span class="skeleton-bar skeleton-bar--medal"></span><span class="popular-info"><span class="skeleton-bar skeleton-bar--title"></span><span class="skeleton-bar skeleton-bar--views"></span></span></div></li>
      </ul>
    </section>

    <div class="search-wrap">
      <input
        id="search"
        type="search"
        placeholder="Search posts..."
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    <script type="application/json" id="posts-meta" is:inline set:html={JSON.stringify(
      sorted.reduce((acc, post) => {
        acc[post.id] = { title: post.title, date: post.date, externalUrl: post.externalUrl };
        return acc;
      }, {} as Record<string, { title: string; date: string; externalUrl?: string }>)
    )}></script>

    <ul class="post-list" id="post-list">
      {sorted.map(post => (
        <li class="post-item" data-title={post.title.toLowerCase()}>
          <a
            href={post.externalUrl ?? `/blog/${post.id}/`}
            class="post-link"
            data-animate
          >
            <div class="post-thumb" transition:name={post.externalUrl ? undefined : `blog-thumb-${post.id}`}>
              <img src={`/og/bg/${post.id}.png`} alt="" />
              <div class="post-body">
                <span class="post-title" transition:name={post.externalUrl ? undefined : `blog-title-${post.id}`}>{post.title}</span>
                <span class="post-meta">
                  <time>{post.date}</time>
                  <span class="sep">·</span>
                  {post.externalUrl ? (
                    <span class="post-tag">UI Lab
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                    </span>
                  ) : (
                    <span>{post.minutes} min read</span>
                  )}
                </span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <p class="no-results" id="no-results" hidden>No posts found.</p>
  </div>
</Layout>

<script>
  function init() {
    const input = document.getElementById('search') as HTMLInputElement;
    const items = document.querySelectorAll<HTMLElement>('.post-item');
    const noResults = document.getElementById('no-results')!;

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;
      for (const item of items) {
        const match = !q || item.dataset.title!.includes(q);
        item.hidden = !match;
        if (match) visible++;
      }
      noResults.hidden = visible > 0;
    });

    const cards = document.querySelectorAll<HTMLElement>('[data-animate]');
    const observer = new IntersectionObserver(
      (observed) => {
        for (const e of observed) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            observer.unobserve(e.target);
          }
        }
      },
      { threshold: 0.08 }
    );
    for (const el of cards) {
      const { top, bottom } = el.getBoundingClientRect();
      if (top < window.innerHeight && bottom > 0) {
        el.classList.add('is-visible');
      } else {
        observer.observe(el);
      }
    }
  }

  function hidePopular() {
    const section = document.getElementById('popular-posts');
    if (section) section.hidden = true;
  }

  function loadPopular() {
    const medals = ['\u{1F947}', '\u{1F948}', '\u{1F949}'];
    const metaEl = document.getElementById('posts-meta');
    if (!metaEl) { hidePopular(); return; }
    const postsMeta: Record<string, { title: string; date: string; externalUrl?: string }> =
      JSON.parse(metaEl.textContent!);

    fetch('/api/views/top')
      .then(r => r.json())
      .then((top: { slug: string; views: number }[]) => {
        if (!top.length) { hidePopular(); return; }
        const list = document.getElementById('popular-list')!;
        list.replaceChildren();

        for (let i = 0; i < top.length; i++) {
          const { slug, views } = top[i];
          const meta = postsMeta[slug];
          if (!meta) continue;
          const href = meta.externalUrl ?? `/blog/${slug}/`;

          const li = document.createElement('li');
          li.className = 'popular-item';
          li.style.setProperty('--card-delay', `${i * 0.06}s`);

          const a = document.createElement('a');
          a.href = href;
          a.className = 'popular-link';

          const medalSpan = document.createElement('span');
          medalSpan.className = 'popular-medal';
          medalSpan.textContent = medals[i];

          const infoSpan = document.createElement('span');
          infoSpan.className = 'popular-info';

          const titleSpan = document.createElement('span');
          titleSpan.className = 'popular-title';
          titleSpan.textContent = meta.title;

          const viewsSpan = document.createElement('span');
          viewsSpan.className = 'popular-views';
          viewsSpan.textContent = `${views.toLocaleString()} views`;

          infoSpan.append(titleSpan, viewsSpan);

          const arrowSpan = document.createElement('span');
          arrowSpan.className = 'popular-arrow';
          arrowSpan.textContent = '\u2192';

          a.append(medalSpan, infoSpan, arrowSpan);
          li.appendChild(a);
          list.appendChild(li);
        }
      })
      .catch(() => { hidePopular(); });
  }

  document.addEventListener('astro:page-load', () => {
    init();
    loadPopular();
  });
</script>

<style>
  .container {
    max-width: 56rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 5rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 3rem;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }
  .back:hover { color: var(--color-fg); }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  h1 {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
  }

  .rss {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.15s ease;
  }
  .rss:hover { color: var(--color-fg); }

  #popular-posts {
    margin-bottom: 2.5rem;
  }

  .popular-heading {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.75rem;
  }

  #popular-posts :global(.popular-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 52rem) {
    #popular-posts :global(.popular-list) {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  #popular-posts :global(.popular-item) {
    min-width: 0;
    opacity: 0;
    transform: translateY(8px);
    animation: popular-enter 0.35s ease forwards;
    animation-delay: var(--card-delay, 0s);
  }

  @keyframes popular-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #popular-posts :global(.popular-link) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.125rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    background: color-mix(in srgb, var(--color-fg) 3%, transparent);
    text-decoration: none;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }

  #popular-posts :global(.popular-link:hover) {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--color-fg) 8%, transparent);
  }

  #popular-posts :global(.popular-medal) {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  #popular-posts :global(.popular-info) {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
    flex: 1;
  }

  #popular-posts :global(.popular-title) {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #popular-posts :global(.popular-views) {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-muted);
  }

  #popular-posts :global(.popular-arrow) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    flex-shrink: 0;
    transition: color 0.15s ease;
  }

  #popular-posts :global(.popular-link:hover .popular-arrow) {
    color: var(--color-fg);
  }

  .popular-skeleton .skeleton-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.125rem;
    border-radius: 12px;
    border: 1px solid color-mix(in srgb, var(--color-fg) 10%, transparent);
    background: color-mix(in srgb, var(--color-fg) 3%, transparent);
  }

  .skeleton-bar {
    display: block;
    border-radius: 4px;
    background: color-mix(in srgb, var(--color-fg) 8%, transparent);
    animation: skeleton-pulse 1.2s ease-in-out infinite;
  }

  .skeleton-bar--medal {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .skeleton-bar--title {
    width: 75%;
    height: 0.82rem;
  }

  .skeleton-bar--views {
    width: 4rem;
    height: 0.6rem;
    margin-top: 0.2rem;
  }

  @keyframes skeleton-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .search-wrap {
    margin-bottom: 2rem;
  }

  #search {
    width: 100%;
    background: color-mix(in srgb, var(--color-fg) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-fg) 12%, transparent);
    border-radius: 6px;
    padding: 0.6rem 0.875rem;
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--color-fg);
    outline: none;
    transition: border-color 0.15s ease;
    box-sizing: border-box;
  }
  #search::placeholder { color: var(--color-muted); }
  #search:focus { border-color: color-mix(in srgb, var(--color-fg) 30%, transparent); }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 52rem) {
    .post-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .post-item {
    display: contents;
  }

  .post-link {
    display: block;
    text-decoration: none;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-fg) 8%, transparent);
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s ease, transform 0.4s ease, box-shadow 0.18s ease;
  }
  .post-link.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  .post-link.is-visible:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 28px color-mix(in srgb, var(--color-fg) 8%, transparent);
  }

  .post-thumb {
    position: relative;
    aspect-ratio: 2 / 1;
    overflow: hidden;
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.3s ease;
  }
  .post-link:hover .post-thumb img {
    transform: scale(1.04);
  }

  .post-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 30%, rgba(255,255,255,0.72) 100%);
    pointer-events: none;
  }

  .post-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .post-body {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 1rem 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .post-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: #1e0e4e;
    line-height: 1.4;
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: rgba(30, 14, 78, 0.6);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .sep { opacity: 0.5; }

  .no-results {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-top: 2rem;
  }
</style>
