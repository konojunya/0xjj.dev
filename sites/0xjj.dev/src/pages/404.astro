---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404">
  <main class="not-found">
    <div class="content">
      <h1 class="code">404</h1>
      <p class="message">Page not found</p>
      <a href="/" class="back">← Back to home</a>
    </div>
  </main>
</Layout>

<script>
  import { haptic } from '../lib/haptic';
  document.querySelector('.back')?.addEventListener('click', () => haptic());
</script>

<style>
  .not-found {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    background: var(--color-bg);
  }

  .content {
    text-align: center;
  }

  .code {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(6rem, 20vw, 12rem);
    line-height: 1;
    margin: 0;
    color: var(--color-fg);
    opacity: 0.12;
  }

  .message {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0.5rem 0 0;
    letter-spacing: 0.04em;
  }

  .back {
    display: inline-block;
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back:hover {
    color: var(--color-fg);
  }
</style>
