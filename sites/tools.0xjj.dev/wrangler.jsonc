{
  "name": "tools-0xjj-dev",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "workers_dev": false,
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "tools-0xjj-dev"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
